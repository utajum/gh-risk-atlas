---
import Base from '../layouts/Base.astro';
// page-level SEO constants
const title       = 'GitHub Risk Atlas - Security Severity Ranking of 3,873 Leaked Repositories';
const description = 'AI-generated severity ranking of 3,873 leaked GitHub-internal repositories. Scored 0–100 by Claude Opus 4.7 (max thinking mode) based on their potential to help an attacker steal GitHub.com customer data. Browse S-tier crown jewels through E-tier low-risk repos.';
const keywords    = 'github leaked repositories, security severity ranking, claude opus AI scoring, github internal repos, attack surface analysis, customer data theft risk, repository security, source code risk assessment, github security breach, leaked source code analysis';
import { ALL_REPOS, STATS, TIER_LABELS, TIER_BANDS, TIER_COLORS, TIER_DESC } from '../data/repos';
import HeroStats from '../components/HeroStats';
import TierBarChart from '../components/TierBarChart';
import ScoreHistogram from '../components/ScoreHistogram';
import TopReposTable from '../components/TopReposTable';
---
<Base title={title} description={description} keywords={keywords}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 px-4">
    <!-- animated background grid -->
    <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(255,45,85,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,45,85,0.03) 1px,transparent 1px);background-size:40px 40px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 50% at 50% -20%,rgba(255,45,85,0.12),transparent);"></div>

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6" style="background:rgba(255,45,85,0.1);border:1px solid rgba(255,45,85,0.3);color:#ff2d55;">
        ⚠ LEAKED INTERNAL REPOSITORIES · SECURITY ANALYSIS
      </div>

      <h1 class="text-5xl sm:text-6xl font-black leading-tight mb-6" style="letter-spacing:-0.03em;">
        GitHub&nbsp;
        <span style="background:linear-gradient(135deg,#ff2d55,#ff6b35);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Risk&nbsp;Atlas</span>
      </h1>

      <p class="text-xl max-w-2xl mx-auto mb-4" style="color:#8b949e;line-height:1.7;">
        AI-generated severity ranking of <strong style="color:#e6edf3;">3,873 leaked GitHub-internal repositories</strong>,
        scored by <strong style="color:#e6edf3;">Claude Opus 4.7</strong> in max thinking mode
        on their potential to help an attacker steal customer data.
      </p>


      <div class="flex flex-wrap justify-center gap-4">
        <a href="/explorer" class="px-6 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105" style="background:linear-gradient(135deg,#ff2d55,#ff6b35);color:white;">
          Explore Dataset -
        </a>
        <a href="/charts" class="px-6 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90" style="background:#161a22;border:1px solid #30363d;color:#e6edf3;">
          View Charts
        </a>
      </div>
    </div>
  </section>

  <!-- Live stat counters -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 -mt-4 mb-16">
    <HeroStats stats={STATS} client:load />
  </section>

  <!-- Tier overview cards -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-bold mb-8">Severity Tiers</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {['S','A','B','C','D','E'].map(tier => {
        const count = STATS.byTier[tier] ?? 0;
        const pct = ((count / STATS.total) * 100).toFixed(1);
        const color = TIER_COLORS[tier];
        return (
          <a href={`/explorer?tier=${tier}`} class="block p-5 rounded-xl transition-all hover:scale-[1.02] hover:shadow-xl no-underline" style={`background:#111318;border:1px solid ${color}33;`}>
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <span class="text-2xl font-black" style={`color:${color};`}>{tier}</span>
                <div>
                  <div class="font-semibold text-sm" style="color:#e6edf3;">{TIER_LABELS[tier]}</div>
                  <div class="text-xs" style="color:#8b949e;">{TIER_BANDS[tier]}</div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-xl font-bold" style={`color:${color};`}>{count}</div>
                <div class="text-xs" style="color:#8b949e;">{pct}%</div>
              </div>
            </div>
            <!-- mini bar -->
            <div class="h-1.5 rounded-full" style="background:#21262d;">
              <div class="h-full rounded-full transition-all" style={`width:${pct}%;background:${color};`}></div>
            </div>
            <p class="mt-3 text-xs leading-relaxed" style="color:#8b949e;">{TIER_DESC[tier]}</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Charts row -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-bold mb-8">Distribution</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="rounded-xl p-6" style="background:#111318;border:1px solid #21262d;">
        <h3 class="font-semibold mb-4" style="color:#8b949e;">Repos per Tier</h3>
        <TierBarChart stats={STATS} client:load />
      </div>
      <div class="rounded-xl p-6" style="background:#111318;border:1px solid #21262d;">
        <h3 class="font-semibold mb-4" style="color:#8b949e;">Score Distribution (0-100)</h3>
        <ScoreHistogram stats={STATS} client:load />
      </div>
    </div>
  </section>

  <!-- Top 20 table -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">Crown Jewels - Top 20</h2>
      <a href="/explorer?tier=S" class="text-sm hover:text-white transition-colors" style="color:#ff2d55;">
        View all S-tier -
      </a>
    </div>
    <TopReposTable repos={ALL_REPOS.slice(0, 20)} client:load />
  </section>
</Base>
